<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#E0E0E0">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="EasiestBudget"
        android:textSize="20sp"
        android:textStyle="bold" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="User"
            android:textSize="18sp"
            android:layout_centerVertical="true"/>
        <Button
            android:id="@+id/btnNewUser"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+ New"
            android:layout_alignParentEnd="true"
            android:backgroundTint="#00C853"/>
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#EDBB99"
        android:padding="5dp"
        android:layout_marginTop="10dp"
        android:weightSum="3">
        <Button android:id="@+id/sortUser" android:layout_width="0dp" android:layout_height="35dp" android:layout_weight="1" android:text="User" android:textSize="10sp" android:backgroundTint="#EDBB99" android:textColor="#000000"/>
        <Button android:id="@+id/sortCategory" android:layout_width="0dp" android:layout_height="35dp" android:layout_weight="1" android:text="Category" android:textSize="10sp" android:backgroundTint="#EDBB99" android:textColor="#000000"/>
        <Button android:id="@+id/sortAmount" android:layout_width="0dp" android:layout_height="35dp" android:layout_weight="1" android:text="Amount" android:textSize="10sp" android:backgroundTint="#EDBB99" android:textColor="#000000"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvUsers"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF"
        android:layout_marginTop="2dp"/>

</LinearLayout>