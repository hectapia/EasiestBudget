<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#E0E0E0">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EasiestBudget"
            android:textSize="20sp"
            android:textStyle="bold" />
        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Back 1"
            android:layout_alignParentEnd="true"
            android:backgroundTint="#154360"/>
    </RelativeLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="New user"
        android:layout_marginTop="20dp"
        android:textSize="18sp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#D6DBDF"
        android:padding="15dp"
        android:layout_marginTop="10dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Name"/>
        <EditText android:id="@+id/etUserName" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Input the user name" android:inputType="textPersonName"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Category" android:layout_marginTop="5dp"/>
        <EditText android:id="@+id/etCategory" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Input category" android:inputType="text"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Budget" android:layout_marginTop="5dp"/>
        <EditText android:id="@+id/etBudgetLimit" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Amount limit &lt; 0.0" android:inputType="numberDecimal"/>
    </LinearLayout>

    <Button
        android:id="@+id/btnAddUser"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Add user"
        android:backgroundTint="#00C853"
        android:layout_marginTop="20dp"/>

</LinearLayout>